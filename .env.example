# ─── Email Configuration ───
# To receive report submissions in your inbox, fill these out.
# Recommended: use Gmail with an App Password (https://myaccount.google.com/apppasswords)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
NOTIFY_TO=where-to-send-reports@example.com

# Optional: override the "from" address shown in emails
# NOTIFY_FROM=your-email@gmail.com

# Optional: override the port the server listens on
# PORT=3000
